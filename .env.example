# ============================================
# 🔥 Firebase Configuration
# ============================================
VITE_FIREBASE_API_KEY="your_firebase_api_key_here"
VITE_FIREBASE_AUTH_DOMAIN="your_project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your_project_id"
VITE_FIREBASE_STORAGE_BUCKET="your_project.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="your_sender_id"
VITE_FIREBASE_APP_ID="1:your_app_id_here"

# ============================================
# 🤖 AI Service Configuration
# ============================================
# Supported providers: OpenAI, Google Gemini, or any OpenAI-compatible API
#
# --- Option A: OpenAI ---
# VITE_AI_API_KEY=sk-your-openai-api-key-here
# VITE_AI_API_URL=https://api.openai.com/v1/chat/completions
#
# --- Option B: Google Gemini ---
# VITE_AI_API_KEY=your-gemini-api-key-here
# VITE_AI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent
#
# --- Option C: OpenAI-compatible (Azure, Groq, etc.) ---
# VITE_AI_API_KEY=your-api-key-here
# VITE_AI_API_URL=https://your-provider.com/v1/chat/completions

VITE_AI_API_KEY=your_ai_api_key_here
VITE_AI_API_URL=https://api.openai.com/v1/chat/completions